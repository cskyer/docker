JENKINS_HTTP_PORT=8090
JENKINS_AGENT_PORT=50000
TZ=Asia/Shanghai
JENKINS_JAVA_OPTS=-Djenkins.install.runSetupWizard=true
JENKINS_HEALTHCHECK_INTERVAL=30s
JENKINS_HEALTHCHECK_TIMEOUT=10s
JENKINS_HEALTHCHECK_RETRIES=5
JENKINS_HEALTHCHECK_START_PERIOD=90s
JENKINS_STOP_GRACE_PERIOD=60s
JENKINS_NOFILE_SOFT_LIMIT=65536
JENKINS_NOFILE_HARD_LIMIT=65536
JENKINS_LOG_MAX_SIZE=10m
JENKINS_LOG_MAX_FILE=5
JENKINS_NETWORK_NAME=jenkins
JENKINS_DATA_VOLUME_NAME=jenkins_data
